# This skill pack has no repo-specific required env vars.
#
# Optional values depending on how you use the included workflows:
# CAMOFOX_URL=        # for a persistent authenticated browser session
# OPENAI_API_KEY=     # or whatever provider key your Hermes install uses
#
# AlphaXiv MCP access is OAuth-based and is typically configured with:
#   hermes mcp add alphaxiv --url https://api.alphaxiv.org/mcp/v1 --auth oauth
#   hermes mcp login alphaxiv
